{
	"compilerOptions": {
		"target": "ES2020",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"lib": [ "ES2020", "DOM", "DOM.Iterable" ],
		"jsx": "preserve",
		"strict": true,
		"noImplicitAny": true,
		"noUnusedLocals": false,
		"noEmit": true,
		"allowJs": false,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"forceConsistentCasingInFileNames": true,
		"paths": {
			"@components": [ "./src/components" ],
			"@components/*": [ "./src/components/*" ],
			"@hooks": [ "./src/hooks" ],
			"@hooks/*": [ "./src/hooks/*" ],
			"@utils": [ "./src/utils" ],
			"@utils/*": [ "./src/utils/*" ]
		},
		"types": []
	},
	"include": [ "src" ],
	"exclude": [ "node_modules", "build", "vendor", "src/**/*.test.ts", "src/**/*.test.tsx" ]
}
