{
	"name": "flexa/flexa-block",
	"description": "Gutenberg Container block with per-device flex layout, light/dark colors and save-time CSS generation.",
	"type": "wordpress-plugin",
	"license": "GPL-3.0-or-later",
	"version": "1.0.0",
	"require": {
		"php": ">=7.4"
	},
	"require-dev": {
		"phpstan/phpstan": "^1.11",
		"phpunit/phpunit": "^9.6",
		"szepeviktor/phpstan-wordpress": "^1.3"
	},
	"scripts": {
		"test": "phpunit",
		"analyse": "phpstan analyse",
		"check": [
			"@analyse",
			"@test"
		]
	},
	"config": {
		"optimize-autoloader": true,
		"sort-packages": true
	}
}
